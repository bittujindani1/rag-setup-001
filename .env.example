AWS_REGION=ap-south-1
LOG_LEVEL=INFO

VECTOR_STORE=s3
DOC_STORE=dynamodb
CHAT_HISTORY_STORE=dynamodb
CACHE_STORE=dynamodb
LLM_PROVIDER=bedrock

BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0
LLM_MODEL=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_FALLBACK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

S3_BUCKET_DOCUMENTS=rag-serverless-documents
S3_BUCKET_VECTORS=rag-serverless-vectors
S3_BUCKET_EXTRACTED=rag-serverless-extracted

DYNAMODB_CHAT_HISTORY_TABLE=rag_chat_history
DYNAMODB_QUERY_CACHE_TABLE=rag_query_cache
DYNAMODB_DOC_STORE_TABLE=rag_doc_store
DYNAMODB_FILENAME_INDEX_TABLE=rag_filename_index
DYNAMODB_RATE_LIMIT_TABLE=rag_rate_limits
DYNAMODB_THREAD_TABLE=rag_chat_threads
DYNAMODB_DOCUMENT_CATEGORIES_TABLE=rag_document_categories
DYNAMODB_INGEST_JOBS_TABLE=rag_ingest_jobs
DYNAMODB_FEEDBACK_TABLE=rag_user_feedback
RATE_LIMIT_REQUESTS_PER_MINUTE=15

RAG_API_URL=http://localhost:8000
TEST_INDEX_NAME=smoke-test-index
TEST_QUERY="What does this document describe?"
TEST_PDF_PATH=
DOCUMENT_EXTRACTOR_VERIFY_SSL=true
DOCUMENT_EXTRACTOR_ALLOW_INSECURE_FALLBACK=true
